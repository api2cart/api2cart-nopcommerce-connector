root = true

[*]
indent_style = space
indent_size = 2
tab_width = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 150

[*.cs]
csharp_new_line_before_open_brace = types,methods,properties,accessors
csharp_new_line_before_else = false
csharp_new_line_before_catch = false
csharp_new_line_before_finally = false
csharp_prefer_braces = true

# Convention (not enforced by formatter):
# Method call arguments: all on one line, or each on its own line with closing ) on its own line.
#   return JsonContent(
#     new BridgeResponse<object> {
#       Result = new {items = result, total_count = totalCount},
#     },
#     statusCode
#   );

[*.{json,xml,csproj}]
indent_size = 2
